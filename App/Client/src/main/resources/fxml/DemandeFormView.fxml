<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>

<VBox
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.campusdocs.client.controller.DemandeFormViewController"
    styleClass="form-root"
    fx:id="rootPane"
    spacing="0">

    <!-- ── Top bar with back arrow ── -->
    <HBox styleClass="form-topbar" alignment="CENTER_LEFT" spacing="16">
        <Button fx:id="btnBack" styleClass="back-btn" onAction="#handleBack" text="&#8592; Retour"/>
        <Label text="Nouvelle demande" styleClass="form-topbar-title"/>
    </HBox>

    <!-- ── Stepper ── -->
    <HBox fx:id="stepperBox" styleClass="stepper" alignment="CENTER" spacing="0">

        <!-- Step 1 -->
        <VBox alignment="CENTER" spacing="6" styleClass="step-item">
            <StackPane>
                <Circle radius="16" fx:id="stepCircle1" styleClass="step-circle, step-active"/>
                <Label text="1" styleClass="step-number"/>
            </StackPane>
            <Label text="Type" styleClass="step-label, step-label-active" fx:id="stepLabel1"/>
        </VBox>
        <Line fx:id="stepLine1" styleClass="step-line" startX="0" endX="60" startY="0" endY="0"/>

        <!-- Step 2 -->
        <VBox alignment="CENTER" spacing="6" styleClass="step-item">
            <StackPane>
                <Circle radius="16" fx:id="stepCircle2" styleClass="step-circle"/>
                <Label text="2" styleClass="step-number"/>
            </StackPane>
            <Label text="Informations" styleClass="step-label" fx:id="stepLabel2"/>
        </VBox>
        <Line fx:id="stepLine2" styleClass="step-line" startX="0" endX="60" startY="0" endY="0"/>

        <!-- Step 3 — NEW: Justificatifs -->
        <VBox alignment="CENTER" spacing="6" styleClass="step-item">
            <StackPane>
                <Circle radius="16" fx:id="stepCircle3" styleClass="step-circle"/>
                <Label text="3" styleClass="step-number"/>
            </StackPane>
            <Label text="Justificatifs" styleClass="step-label" fx:id="stepLabel3"/>
        </VBox>
        <Line fx:id="stepLine3" styleClass="step-line" startX="0" endX="60" startY="0" endY="0"/>

        <!-- Step 4 — Validate -->
        <VBox alignment="CENTER" spacing="6" styleClass="step-item">
            <StackPane>
                <Circle radius="16" fx:id="stepCircle4" styleClass="step-circle"/>
                <Label text="4" styleClass="step-number"/>
            </StackPane>
            <Label text="Valider" styleClass="step-label" fx:id="stepLabel4"/>
        </VBox>

    </HBox>

    <!-- ── Step content area ── -->
    <StackPane fx:id="stepContent" VBox.vgrow="ALWAYS" styleClass="step-content-area">

        <!-- STEP 1 — Choisir type de document -->
        <ScrollPane fx:id="step1" fitToWidth="true" styleClass="step-scroll" hbarPolicy="NEVER">
            <content>
                <VBox spacing="20" styleClass="step-inner">
                    <Label text="Choisissez le type de document" styleClass="step-title"/>
                    <Label text="Sélectionnez un document parmi les catégories ci-dessous." styleClass="step-subtitle"/>

                    <GridPane fx:id="docTypeGrid" hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="33.33"/>
                            <ColumnConstraints percentWidth="33.33"/>
                            <ColumnConstraints percentWidth="33.33"/>
                        </columnConstraints>

                        <!-- Cards injected by controller -->
                    </GridPane>
                </VBox>
            </content>
        </ScrollPane>

        <!-- STEP 2 — Remplir les informations -->
        <ScrollPane fx:id="step2" fitToWidth="true" styleClass="step-scroll" hbarPolicy="NEVER" visible="false" managed="false">
            <content>
                <VBox spacing="20" styleClass="step-inner">
                    <Label text="Remplissez les informations" styleClass="step-title"/>
                    <Label fx:id="step2Subtitle" text="Complétez les champs requis pour votre demande." styleClass="step-subtitle"/>
                    <VBox fx:id="dynamicFormContainer" spacing="16">
                        <!-- Dynamic form fields injected by controller based on doc type -->
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
        
        <!-- STEP 3 — Justificatifs -->
        <ScrollPane fx:id="step3" fitToWidth="true" styleClass="step-scroll"
                    hbarPolicy="NEVER" visible="false" managed="false">
            <content>
                <VBox spacing="20" styleClass="step-inner">

                    <Label text="Pièces justificatives" styleClass="step-title"/>
                    <Label fx:id="justifSubtitle"
                           text="Téléversez les documents requis pour votre demande."
                           styleClass="step-subtitle"/>

                    <!-- Error label — shown when required files are missing -->
                    <Label fx:id="justifErrorLabel"
                           text=""
                           styleClass="error-label"
                           visible="false" managed="false"
                           wrapText="true"/>

                    <!-- Upload slots injected by controller -->
                    <VBox fx:id="justifContainer" spacing="12"/>

                </VBox>
            </content>
        </ScrollPane>

        <!-- STEP 4 — Valider demande -->
        <ScrollPane fx:id="step4" fitToWidth="true" styleClass="step-scroll" hbarPolicy="NEVER" visible="false" managed="false">
            <content>
                <VBox spacing="24" styleClass="step-inner">
                    <Label text="Aperçu de votre demande" styleClass="step-title"/>
                    <Label text="Vérifiez les informations avant de valider." styleClass="step-subtitle"/>

                    <!-- Overview card -->
                    <VBox styleClass="overview-card" spacing="14">
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Circle radius="8" styleClass="overview-dot"/>
                            <Label fx:id="overviewDocType" text="—" styleClass="overview-doc-type"/>
                        </HBox>
                        <Separator/>
                        <VBox fx:id="overviewFields" spacing="8">
                            <!-- Injected by controller -->
                        </VBox>
                        <Separator/>
                        <HBox>
                            <Label text="Montant payé" styleClass="summary-key" HBox.hgrow="ALWAYS"/>
                            <Label fx:id="overviewAmount" text="500 FCFA" styleClass="summary-val-bold"/>
                        </HBox>
                    </VBox>

                    <!-- Download PDF -->
                    <Button fx:id="btnDownloadPdf" styleClass="download-btn" onAction="#handleDownloadPdf" maxWidth="Infinity">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8">
                                <ImageView
                                fx:id="leftPaneImage" 
                                fitHeight="24"
                                preserveRatio="true"
                                >
                                    <image>                             
                                        <Image url="/icons/download_light.png" />
                                    </image>
                                </ImageView>
                                <Label text="Télécharger le récapitulatif en PDF" styleClass="download-label"/>
                            </HBox>
                        </graphic>
                    </Button>

                </VBox>
            </content>
        </ScrollPane>

    </StackPane>

    <!-- ── Bottom navigation ── -->
    <HBox styleClass="form-footer" alignment="CENTER_RIGHT" spacing="12">
        <Button fx:id="btnPrecedent" styleClass="btn-secondary" onAction="#handlePrecedent" text="&#8592; Précédent" disable="true"/>
        <Button fx:id="btnSuivant"  styleClass="action-btn"    onAction="#handleSuivant"   text="Suivant &#8594;"/>
    </HBox>

</VBox>
