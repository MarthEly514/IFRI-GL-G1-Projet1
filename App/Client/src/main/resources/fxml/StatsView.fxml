    xmlns:fx="http://javafx.com/fxml/1"
    fx:id="statsView" 
    fx:controller="com.campusdocs.client.controller.StatsViewController"
    spacing="20" 
    styleClass="view-container" 
    stylesheets="@/styles/statsview.css"
    visible="false" managed="false">
    <Label text="Mon profil" styleClass="section-title"/>
    <HBox styleClass="profile-card" spacing="20" alignment="CENTER_LEFT">
        <Circle radius="36" styleClass="profile-avatar-large"/>
        <VBox spacing="4">
            <Label text="Étudiant CampusDocs" styleClass="welcome-title"/>
            <Label text="etudiant@campusdocs.com" styleClass="activity-sub"/>
