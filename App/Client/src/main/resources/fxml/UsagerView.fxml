<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.shape.*?>

<VBox 
    xmlns="http://javafx.com/javafx"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.campusdocs.client.controller.UsagerViewController"
    fx:id="usagerView" 
    spacing="24" 
    styleClass="view-container">

    <!-- Welcome banner -->
    <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="0">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label fx:id="welcomeTitle" text="Bonjour !" styleClass="welcome-title"/>
            <Label text="Bienvenue sur votre portail CampusDocs." styleClass="welcome-sub"/>
        </VBox>
        <ImageView fx:id="bannerImage" fitHeight="150" preserveRatio="true"/>
    </HBox>

    <!-- Stats row -->
    <VBox spacing="12">
        <Label text="Vue d'ensemble" styleClass="section-title"/>
        <HBox spacing="16">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                <Label text="DEMANDES EN COURS" styleClass="stat-label"/>
                <Label fx:id="statDemandesEnCours" text="—" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                <Label text="ACTES DISPONIBLES" styleClass="stat-label"/>
                <Label fx:id="statActesDisponibles" text="—" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="4">
                <Label text="DEMANDES TOTALES" styleClass="stat-label"/>
                <Label fx:id="statDemandesTotales" text="—" styleClass="stat-value"/>
            </VBox>
            <VBox styleClass="stat-card, stat-card-accent" HBox.hgrow="ALWAYS" spacing="4">
                <Label text="ACTES TOTAUX" styleClass="stat-label"/>
                <Label fx:id="statActesTotaux" text="—" styleClass="stat-value-accent"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Recent activity -->
    <VBox spacing="12">
        <Label text="Activité récente" styleClass="section-title"/>
        <VBox fx:id="activityContainer" spacing="8">
            <!-- Injected by controller -->
        </VBox>
    </VBox>

</VBox>